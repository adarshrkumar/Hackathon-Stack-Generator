---
/**
  * About Page
  *
  * Provides information about the BuildLoom application, its mission,
  * and how it helps different user types (startups, enterprises, developers, consultants).
  *
  * Sections:
  * - About Intro: Project overview and value proposition
  * - Mission Statement: Core purpose and goals (in FancyCard)
  * - How We Help: Benefits for different user segments
  * - What We Cover: Service categories and providers
  * - Our Approach: Methodology and data sources
  * - CTA: Call-to-action to start using the app
  *
  * Layout: Uses Layout.astro (Header + Hero + Footer)
  */

// Import marketing layout
import Layout from '../layouts/Layout.astro';

// Import FancyCard for styled content sections
import FancyCard from '../components/FancyCard.astro';
---

<!-- About Page Content -->
<Layout title="About">
    <section class="about-intro">
        <h1>About Tech Stack Generator</h1>
        <p class="lead">Choosing the right technology stack is hard. Our AI-powered assistant helps you find the perfect fit for your project in minutes, not days.</p>
    </section>

    <FancyCard padding="2.5rem" maxWidth="900px" centered>
        <div class="mission">
            <h2>Our Mission</h2>
            <p>We empower developers, tech leads, and decision-makers to make better technology choices by providing personalized, AI-powered recommendations. Whether you're launching a startup, planning a migration, or exploring new architectures, we help you discover technology stacks that align with your project needs and goals.</p>
        </div>
    </FancyCard>

    <section class="how-we-help">
        <h2>How We Help You Succeed</h2>
        <div class="help-grid">
            <div class="help-card">
                <div class="help-icon">🎯</div>
                <h3>For Startups</h3>
                <p>Get personalized tech stack recommendations that fit your project scope and team expertise. Make confident technology choices from day one.</p>
            </div>
            <div class="help-card">
                <div class="help-icon">🏢</div>
                <h3>For Enterprises</h3>
                <p>Explore architectural recommendations and best practices for scaling. Present stakeholders with clear technology strategies backed by practical guidance.</p>
            </div>
            <div class="help-card">
                <div class="help-icon">👨‍💻</div>
                <h3>For Developers</h3>
                <p>Explore different technology approaches and architectural patterns. Learn best practices and get hands-on guidance for implementation.</p>
            </div>
            <div class="help-card">
                <div class="help-icon">🤝</div>
                <h3>For Tech Leaders</h3>
                <p>Make informed technology decisions with AI-powered insights. Justify your architectural choices with clear explanations and practical recommendations.</p>
            </div>
        </div>
    </section>

    <section class="what-we-cover">
        <h2>What We Cover</h2>
        <div class="coverage-list">
            <div class="coverage-item">
                <h3>☁️ Cloud Providers</h3>
                <p>AWS, Azure, Google Cloud Platform, DigitalOcean, Linode, and more</p>
            </div>
            <div class="coverage-item">
                <h3>🗄️ Databases</h3>
                <p>PostgreSQL, MySQL, MongoDB, Redis, DynamoDB, and managed database services</p>
            </div>
            <div class="coverage-item">
                <h3>🚀 Hosting & CDN</h3>
                <p>Vercel, Netlify, Cloudflare, AWS CloudFront, Fastly, and edge computing platforms</p>
            </div>
            <div class="coverage-item">
                <h3>📈 Monitoring & Analytics</h3>
                <p>Datadog, New Relic, Sentry, LogRocket, Google Analytics, and observability tools</p>
            </div>
            <div class="coverage-item">
                <h3>🔐 Authentication & Security</h3>
                <p>Auth0, Okta, AWS Cognito, Firebase Auth, and security services</p>
            </div>
            <div class="coverage-item">
                <h3>📧 Communication Services</h3>
                <p>SendGrid, Twilio, AWS SES, Mailgun, and notification platforms</p>
            </div>
        </div>
    </section>

    <section class="our-approach">
        <h2>How We Work</h2>
        <div class="approach-content">
            <div class="approach-item">
                <h3>AI-Powered Conversations</h3>
                <p>Our AI assistant engages in natural conversations to understand your project needs, constraints, and goals before recommending a technology stack.</p>
            </div>
            <div class="approach-item">
                <h3>Comprehensive Database</h3>
                <p>We maintain a database of hundreds of cloud services, frameworks, databases, and tools. Our AI accesses current information to provide relevant recommendations.</p>
            </div>
            <div class="approach-item">
                <h3>Practical Guidance</h3>
                <p>Beyond recommendations, we provide architectural patterns, integration strategies, and best practices to help you implement your chosen stack.</p>
            </div>
            <div class="approach-item">
                <h3>Continuous Learning</h3>
                <p>We're constantly expanding our technology coverage and improving our recommendations based on user feedback.</p>
            </div>
        </div>
    </section>

    <section class="cta-about">
        <h2>Ready to Get Started?</h2>
        <p>Join developers and teams who are making smarter technology decisions with data-driven insights.</p>
        <a href="/app" class="btn-primary-large">Start Building Your Stack</a>
    </section>
</Layout>

<style lang="scss">
    @use '../styles/pages/about.scss';
</style>