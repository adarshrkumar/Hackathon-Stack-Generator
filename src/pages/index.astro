---
/**
  * Homepage (Index Page)
  *
  * Main landing page for the Stack Generator application.
  * Showcases the product's key features, benefits, and how it works.
  *
  * Sections:
  * - Key Features: 6 main product features in a grid
  * - How It Works: 3-step process explanation
  * - Benefits: Why use the ROI calculator (using FancyCard components)
  * - CTA: Call-to-action buttons to start building or learn more
  *
  * Layout: Uses Layout.astro which includes Header, Hero, and Footer
  */

// Import the marketing layout
import Layout from '../layouts/Layout.astro';

// Import FancyCard component for styled content sections
import FancyCard from '../components/FancyCard.astro';
---

<!-- Homepage Content -->
<Layout title="Home">
    <!-- Key Features Section -->
    <section class="features">
        <h2>Key Features</h2>

        <!-- Features Grid (6 feature cards) -->
        <div class="features-grid">
            <!-- Feature 1: AI-Powered Assistant -->
            <div class="feature-card">
                <h3>🤖 AI-Powered Assistant</h3>
                <p>Chat with an intelligent assistant that understands your project needs and provides personalized tech stack recommendations based on your requirements.</p>
            </div>

            <!-- Feature 2: Database of Technologies -->
            <div class="feature-card">
                <h3>📚 Database of Technologies</h3>
                <p>Access information about hundreds of cloud services, databases, frameworks, and tools. Get details on the latest technologies and services.</p>
            </div>

            <!-- Feature 3: Architectural Guidance -->
            <div class="feature-card">
                <h3>🏛️ Architectural Guidance</h3>
                <p>Receive practical recommendations on project structure, architectural patterns, and best practices for your specific use case.</p>
            </div>

            <!-- Feature 4: Technology Comparison -->
            <div class="feature-card">
                <h3>⚖️ Technology Comparison</h3>
                <p>Explore different tech stack options side-by-side. Understand the trade-offs between different approaches and find the best fit for your needs.</p>
            </div>

            <!-- Feature 5: Documentation & Learning -->
            <div class="feature-card">
                <h3>📖 Documentation & Learning</h3>
                <p>Get access to relevant documentation and resources for the technologies recommended, helping you learn as you build.</p>
            </div>

            <!-- Feature 6: Conversation History -->
            <div class="feature-card">
                <h3>💬 Conversation History</h3>
                <p>Maintain persistent chat threads with your recommendations. Save and revisit your tech stack discussions anytime.</p>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works">
        <h2>How It Works</h2>

        <!-- 3-Step Process -->
        <div class="steps">
            <!-- Step 1 -->
            <div class="step">
                <div class="step-number">1</div>
                <h3>Describe Your Project</h3>
                <p>Tell the AI what type of application or product you're building. Provide context about your goals, scale, and any specific constraints.</p>
            </div>

            <!-- Step 2 -->
            <div class="step">
                <div class="step-number">2</div>
                <h3>Ask Questions</h3>
                <p>Have a conversation with the AI. Ask about specific technologies, explore different approaches, and get clarification on recommendations.</p>
            </div>

            <!-- Step 3 -->
            <div class="step">
                <div class="step-number">3</div>
                <h3>Get Recommendations</h3>
                <p>Receive a personalized tech stack recommendation with explanations of why each technology is a good fit for your project.</p>
            </div>
        </div>
    </section>

    <!-- Benefits Section -->
    <section class="benefits">
        <h2>Why Use Tech Stack Generator?</h2>

        <!-- Benefits List (using FancyCard components) -->
        <div class="benefits-list">
            <!-- Benefit 1: Informed Decisions -->
            <FancyCard>
                <strong>Make Informed Decisions:</strong> Get personalized tech stack recommendations from an AI that understands your project context and goals.
            </FancyCard>

            <!-- Benefit 2: Reduce Research Time -->
            <FancyCard>
                <strong>Reduce Research Time:</strong> Skip hours of manual research and comparison. Get curated recommendations in minutes instead of days.
            </FancyCard>

            <!-- Benefit 3: Learn Best Practices -->
            <FancyCard>
                <strong>Learn Best Practices:</strong> Understand architectural patterns, integration strategies, and practical implementation guidance for your tech stack.
            </FancyCard>

            <!-- Benefit 4: Justify Your Choices -->
            <FancyCard>
                <strong>Justify Your Choices:</strong> Present stakeholders with clear explanations of why you selected specific technologies and how they solve your project needs.
            </FancyCard>
        </div>
    </section>

    <!-- Call to Action Section -->
    <section class="cta">
        <h2>Ready to Build Your Perfect Stack?</h2>
        <p>Start a conversation with our AI assistant and get personalized tech stack recommendations for your project.</p>

        <!-- CTA Buttons -->
        <div class="cta-buttons">
            <a href="/app" class="btn btn-primary">Start Building</a>
            <a href="/about" class="btn btn-secondary">Learn More</a>
        </div>
    </section>
</Layout>

<!-- Page-specific Styles -->
<style lang="scss">
    @use '../styles/pages/index.scss';
</style>