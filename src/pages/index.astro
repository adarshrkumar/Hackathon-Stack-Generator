---
/**
  * Homepage (Index Page)
  *
  * Main landing page for the Stack Generator application.
  * Showcases the product's key features, benefits, and how it works.
  *
  * Sections:
  * - Key Features: 6 main product features in a grid
  * - How It Works: 3-step process explanation
  * - Benefits: Why use the ROI calculator (using FancyCard components)
  * - CTA: Call-to-action buttons to start building or learn more
  *
  * Layout: Uses Layout.astro which includes Header, Hero, and Footer
  */

// Import the marketing layout
import Layout from '../layouts/Layout.astro';

// Import FancyCard component for styled content sections
import FancyCard from '../components/FancyCard.astro';
---

<!-- Homepage Content -->
<Layout title="Home">
    <!-- Key Features Section -->
    <section class="features">
        <h2>Key Features</h2>

        <!-- Features Grid (6 feature cards) -->
        <div class="features-grid">
            <!-- Feature 1: Stack Builder -->
            <div class="feature-card">
                <h3>🏗️ Stack Builder</h3>
                <p>Select from a comprehensive library of cloud services, databases, frameworks, and tools to design your perfect tech stack.</p>
            </div>

            <!-- Feature 2: Service Information -->
            <div class="feature-card">
                <h3>💰 Service Information</h3>
                <p>Access current information for AWS, Azure, GCP, and other services. Information is updated regularly to reflect the latest details.</p>
            </div>

            <!-- Feature 3: Infrastructure Analysis -->
            <div class="feature-card">
                <h3>📈 Infrastructure Analysis</h3>
                <p>Discover your projected infrastructure based on industry benchmarks, development time, and operational efficiency gains.</p>
            </div>

            <!-- Feature 4: Compare Alternatives -->
            <div class="feature-card">
                <h3>⚖️ Compare Alternatives</h3>
                <p>Evaluate different tech stack configurations side-by-side. Find the optimal balance between requirements and performance.</p>
            </div>

            <!-- Feature 5: Resource Breakdown -->
            <div class="feature-card">
                <h3>📊 Resource Breakdown</h3>
                <p>Visualize detailed breakdowns by service category, region, and time period.</p>
            </div>

            <!-- Feature 6: Smart Recommendations -->
            <div class="feature-card">
                <h3>💡 Smart Recommendations</h3>
                <p>Get AI-powered suggestions for optimization and alternative services that deliver better options for your use case.</p>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works">
        <h2>How It Works</h2>

        <!-- 3-Step Process -->
        <div class="steps">
            <!-- Step 1 -->
            <div class="step">
                <div class="step-number">1</div>
                <h3>Select Your Stack</h3>
                <p>Choose the services and tools you need: cloud providers, databases, frameworks, CDNs, monitoring tools, and more.</p>
            </div>

            <!-- Step 2 -->
            <div class="step">
                <div class="step-number">2</div>
                <h3>Configure Resources</h3>
                <p>Specify your requirements: expected traffic, storage needs, compute resources, and deployment regions.</p>
            </div>

            <!-- Step 3 -->
            <div class="step">
                <div class="step-number">3</div>
                <h3>See Results</h3>
                <p>Get instant results of monthly rates, implementation time, and detailed breakdowns with recommendations.</p>
            </div>
        </div>
    </section>

    <!-- Benefits Section -->
    <section class="benefits">
        <h2>Why Use Tech Stack Generator?</h2>

        <!-- Benefits List (using FancyCard components) -->
        <div class="benefits-list">
            <!-- Benefit 1: Avoid Overruns -->
            <FancyCard>
                <strong>Avoid Overruns:</strong> Know the details before you build. Plan ahead to prevent issues that can derail your project.
            </FancyCard>

            <!-- Benefit 2: Data-Driven Decisions -->
            <FancyCard>
                <strong>Make Data-Driven Decisions:</strong> Compare multiple stack options with real data. Choose the configuration that works best for your specific needs.
            </FancyCard>

            <!-- Benefit 3: Accelerate Planning -->
            <FancyCard>
                <strong>Accelerate Planning:</strong> Skip the hours of manual research. Get comprehensive analysis in minutes, not days.
            </FancyCard>

            <!-- Benefit 4: Justify Your Choices -->
            <FancyCard>
                <strong>Justify Your Choices:</strong> Present stakeholders with detailed projections and breakdowns. Build confidence in your technical decisions with solid data.
            </FancyCard>
        </div>
    </section>

    <!-- Call to Action Section -->
    <section class="cta">
        <h2>Ready to Build Your Perfect Stack?</h2>
        <p>Make informed decisions about your tech infrastructure today.</p>

        <!-- CTA Buttons -->
        <div class="cta-buttons">
            <a href="/app" class="btn btn-primary">Start Building</a>
            <a href="/about" class="btn btn-secondary">Learn More</a>
        </div>
    </section>
</Layout>

<!-- Page-specific Styles -->
<style lang="scss">
    @use '../styles/pages/index.scss';
</style>