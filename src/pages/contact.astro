---
/**
  * Contact Page
  *
  * Provides contact information, social media links, FAQs, and project details.
  *
  * Sections:
  * - Contact Intro: Page introduction
  * - Contact Methods: Email addresses for different inquiries (using FancyCard)
  * - Social Links: GitHub, Twitter, LinkedIn, Discord
  * - FAQ Preview: Common questions and answers
  * - Project Info: SCU AWS Hackathon details and support hours
  * - CTA: Call-to-action to start using the app
  *
  * Layout: Uses Layout.astro (Header + Hero + Footer)
  */

// Import marketing layout
import Layout from '../layouts/Layout.astro';

// Import FancyCard for styled content sections
import FancyCard from '../components/FancyCard.astro';
---

<!-- Contact Page Content -->
<Layout title="Contact">
    <section class="contact-intro">
        <h1>Get In Touch</h1>
        <p class="lead">Have questions about Tech Stack Generator? We'd love to hear from you.</p>
    </section>

    <section class="contact-methods">
        <h2>Contact Information</h2>
        <div class="methods-grid">
            <FancyCard padding="2rem">
                <div class="method-card">
                    <div class="method-icon">📧</div>
                    <h3>Email Us</h3>
                    <p>For general inquiries and support</p>
                    <a href="mailto:support@stackcalculator.com" class="contact-link">support@stackcalculator.com</a>
                </div>
            </FancyCard>
            <FancyCard padding="2rem">
                <div class="method-card">
                    <div class="method-icon">💼</div>
                    <h3>Business Inquiries</h3>
                    <p>Partnership and enterprise opportunities</p>
                    <a href="mailto:business@stackcalculator.com" class="contact-link">business@stackcalculator.com</a>
                </div>
            </FancyCard>
            <FancyCard padding="2rem">
                <div class="method-card">
                    <div class="method-icon">🐛</div>
                    <h3>Report Issues</h3>
                    <p>Found a bug or have feedback?</p>
                    <a href="https://github.com/yourusername/repo/issues" class="contact-link" target="_blank">GitHub Issues</a>
                </div>
            </FancyCard>
        </div>
    </section>

    <section class="social-section">
        <h2>Connect With Us</h2>
        <div class="social-grid">
            <a href="#" class="social-card" target="_blank">
                <div class="social-icon">💻</div>
                <h3>GitHub</h3>
                <p>View our code and contribute</p>
            </a>
            <a href="#" class="social-card" target="_blank">
                <div class="social-icon">🐦</div>
                <h3>Twitter</h3>
                <p>Follow for updates</p>
            </a>
            <a href="#" class="social-card" target="_blank">
                <div class="social-icon">💼</div>
                <h3>LinkedIn</h3>
                <p>Connect professionally</p>
            </a>
            <a href="#" class="social-card" target="_blank">
                <div class="social-icon">💬</div>
                <h3>Discord</h3>
                <p>Join our community</p>
            </a>
        </div>
    </section>

    <section class="faq-preview">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
            <FancyCard>
                <h3>How accurate is the information?</h3>
                <p>Our AI understands your project description and requirements, then queries our database of technologies and services to provide personalized recommendations suited to your specific needs.</p>
            </FancyCard>
            <FancyCard>
                <h3>Is this tool free to use?</h3>
                <p>Yes! Tech Stack Generator was built as part of the SCU AWS Hackathon and is currently free to use for all users.</p>
            </FancyCard>
            <FancyCard>
                <h3>Which technologies do you cover?</h3>
                <p>We cover cloud providers (AWS, Azure, GCP, etc.), databases, frameworks, hosting platforms, monitoring tools, authentication services, and many other technology categories. We're continuously expanding our coverage.</p>
            </FancyCard>
            <FancyCard>
                <h3>Can I save my stack configurations?</h3>
                <p>Yes! Your conversations are saved in persistent threads that you can access anytime. This lets you maintain your tech stack discussions and revisit recommendations.</p>
            </FancyCard>
        </div>
    </section>

    <section class="office-info">
        <h2>Project Information</h2>
        <div class="info-content">
            <div class="info-card">
                <h3>🎓 SCU AWS Hackathon Project</h3>
                <p>This tool was developed as part of the Santa Clara University AWS Hackathon. It showcases how AI can help developers make better technology decisions.</p>
            </div>
            <div class="info-card">
                <h3>⏰ Support Hours</h3>
                <p>We typically respond to inquiries within 24-48 hours during weekdays. For urgent issues, please use our GitHub issues tracker.</p>
            </div>
        </div>
    </section>

    <section class="cta-contact">
        <h2>Ready to Start?</h2>
        <p>Don't wait – start building and analyzing your tech stack today.</p>
        <a href="/app" class="btn-primary-large">Start Building Your Stack</a>
    </section>
</Layout>

<style lang="scss">
    @use '../styles/pages/contact.scss';
</style>
